<%- include('partials/header') %>

<section class="page-section">
  <div class="content-card">
    <h1>Contact Spoon Specialty Services</h1>

    <p>
      Have a question or need a service? Complete the form below and we will contact
      you as soon as possible.
    </p>

    <form class="business-form" action="/contact-request" method="POST">
      <div class="form-group">
        <label>Full Name</label>
        <input type="text" name="fullName" required>
      </div>

      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" required>
      </div>

      <div class="form-group">
        <label>Phone Number</label>
        <input type="tel" name="phone">
      </div>

      <div class="form-group">
        <label>Service Needed</label>
        <select name="serviceNeeded">
          <option>Travel Booking</option>
          <option>Web Design</option>
          <option>Courier Services</option>
          <option>Author / Book Services</option>
          <option>General Question</option>
        </select>
      </div>

      <div class="form-group">
        <label>Message</label>
        <textarea name="message" rows="6" placeholder="How can we help you?"></textarea>
      </div>

      <button type="submit" class="submit-btn">Send Message</button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>