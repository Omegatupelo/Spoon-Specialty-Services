<%- include("partials/header") %>

<section class="contact-page">

    <div class="contact-overlay">

        <div class="contact-container">

            <div class="contact-left">

                <h4 class="contact-subtitle">
                    CONTACT SPOON SPECIALTY SERVICES
                </h4>

                <h1 class="contact-title">
                    Let’s Build Something Great Together
                </h1>

                <p class="contact-text">
                    Need travel booking, website development,
                    courier services, or business solutions?
                    Send us a message and we will contact you shortly.
                </p>

                <div class="contact-info">

                    <div class="info-box">
                        <h3>Email</h3>
                        <p>spoonspecialtyservices@yahoo.com</p>
                    </div>

                    <div class="info-box">
                        <h3>Website</h3>

                        <a
                            href="https://www.spoonspecialtyservices.com"
                            target="_blank"
                        >
                            www.spoonspecialtyservices.com
                        </a>
                    </div>

                </div>

            </div>

            <div class="contact-right">

                <form
                    action="/contact"
                    method="POST"
                    class="contact-form"
                >

                    <input
                        type="text"
                        name="name"
                        placeholder="Full Name"
                        required
                    />

                    <input
                        type="email"
                        name="email"
                        placeholder="Email Address"
                        required
                    />

                    <input
                        type="text"
                        name="phone"
                        placeholder="Phone Number"
                    />

                    <textarea
                        name="message"
                        rows="6"
                        placeholder="Tell us how we can help..."
                        required
                    ></textarea>

                    <button type="submit">
                        Send Message
                    </button>

                </form>

            </div>

        </div>

    </div>

</section>

<%- include("partials/footer") %>