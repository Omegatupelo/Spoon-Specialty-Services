<%- include('partials/header') %>

<section class="booking-page">
  <div class="booking-card">
    <h1>Book a Service</h1>

    <p>
      Request a consultation, appointment, courier service, travel quote, or website project.
      We will review your request and contact you to confirm availability.
    </p>

    <form class="business-form" action="/booking-request" method="POST">
      <div class="form-group">
        <label>Full Name</label>
        <input type="text" name="fullName" required>
      </div>

      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" required>
      </div>

      <div class="form-group">
        <label>Phone Number</label>
        <input type="tel" name="phone" required>
      </div>

      <div class="form-group">
        <label>Service Type</label>
        <select name="serviceType" required>
          <option value="">Select a service</option>
          <option>Travel Consultation</option>
          <option>Website Consultation</option>
          <option>Courier Request</option>
          <option>Author / Book Branding</option>
          <option>General Business Consultation</option>
        </select>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Preferred Date</label>
          <input type="date" name="preferredDate">
        </div>

        <div class="form-group">
          <label>Preferred Time</label>
          <input type="time" name="preferredTime">
        </div>
      </div>

      <div class="form-group">
        <label>Details</label>
        <textarea name="details" rows="6" placeholder="Tell us what you need..."></textarea>
      </div>

      <button type="submit" class="submit-btn">Submit Booking Request</button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>