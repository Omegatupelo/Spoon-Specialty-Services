<%- include('partials/header') %>

<section class="courier-page">

  <div class="courier-card">

    <h1>Courier Request Form</h1>

    <p>
      Request fast, secure, and reliable courier services
      for local, business, or medical deliveries.
    </p>

    <form
      class="courier-form"
      action="/courier-request"
      method="POST"
    >

      <div class="form-group">
        <label>Full Name</label>

        <input
          type="text"
          name="fullName"
          required
        >
      </div>

      <div class="form-group">
        <label>Email Address</label>

        <input
          type="email"
          name="email"
          required
        >
      </div>

      <div class="form-group">
        <label>Phone Number</label>

        <input
          type="tel"
          name="phone"
          required
        >
      </div>

      <div class="form-group">
        <label>Pickup Address</label>

        <input
          type="text"
          name="pickupAddress"
          required
        >
      </div>

      <div class="form-group">
        <label>Delivery Address</label>

        <input
          type="text"
          name="deliveryAddress"
          required
        >
      </div>

      <div class="form-group">
        <label>Package Type</label>

        <select name="packageType">

          <option>Documents</option>

          <option>Medical Delivery</option>

          <option>Small Package</option>

          <option>Large Package</option>

          <option>Fragile Item</option>

        </select>
      </div>

      <div class="form-group">
        <label>Requested Pickup Date</label>

        <input
          type="date"
          name="pickupDate"
        >
      </div>

      <div class="form-group">
        <label>Additional Details</label>

        <textarea
          name="details"
          rows="6"
          placeholder="Describe the delivery request..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="submit-btn"
      >
        Submit Courier Request
      </button>

    </form>

  </div>

</section>

<%- include('partials/footer') %>